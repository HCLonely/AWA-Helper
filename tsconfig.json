{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "./src",
    "sourceMap": false,
    "strict": true,
    "declaration": false,
    "declarationMap": false,
    "moduleResolution": "node10",
    "module": "CommonJS",
    "target": "es2022",
    "allowJs": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/DailyQuestUS.ts",
    "src/SteamQuestSU.ts"
  ]
}
